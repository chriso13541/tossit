{
  "node": {
    "name": "my-node",
    "port": 8000,
    "storage_path": "~/.tossit/storage",
    "storage_limit_gb": 100
  },
  "cluster": {
    "cluster_id": "auto-generated on first run (8 hex chars)",
    "heartbeat_interval_seconds": 2,
    "election_timeout_min_seconds": 15,
    "election_timeout_max_seconds": 25
  },
  "replication": {
    "chunk_size_mb": 64,
    "factor_small_cluster": 2,
    "factor_large_cluster": 3,
    "small_cluster_threshold": 4
  },
  "registry": {
    "url": "https://tossit.cc",
    "note": "Set via TOSSIT_REGISTRY_URL environment variable"
  }
}
